# ─── Admin Password ────────────────────────────────────────────────────────────
# Default is "ADMIN" if not set. Change this to a strong password for production.
ADMIN_PASSWORD=ADMIN

# ─── Hedera ───────────────────────────────────────────────────────────────────
# Create a free account at portal.hedera.com
# Start on TESTNET — switch to mainet when ready
HEDERA_NETWORK=testnet
HEDERA_TREASURY_ID=0.0.5669964

HEDERA_TREASURY_KEY=YOUR_PRIVATE_KEY_HEX



# ─── IPFS / Pinata ────────────────────────────────────────────────────────────
# Free account at pinata.cloud — 1GB free storage
PINATA_API_KEY=your_pinata_api_key
PINATA_API_SECRET=your_pinata_api_secret

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

