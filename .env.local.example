# ─── Hedera ───────────────────────────────────────────────────────────────────
# Create a free Hedera account at portal.hedera.com
# Start on TESTNET — switch to mainnet when ready for real donations

HEDERA_NETWORK=testnet
HEDERA_TREASURY_ID=0.0.YOUR_ACCOUNT_ID
HEDERA_TREASURY_KEY=YOUR_PRIVATE_KEY_HEX

# ─── IPFS / Pinata ────────────────────────────────────────────────────────────
# Free account at pinata.cloud — gives you 1GB free storage
# This stores your NFT metadata and images permanently

PINATA_API_KEY=your_pinata_api_key
PINATA_API_SECRET=your_pinata_api_secret

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
